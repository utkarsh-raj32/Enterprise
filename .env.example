# ==============================================================================
# ENVIRONMENT VARIABLES EXAMPLE FILE
# ==============================================================================
# This is an example file. Do NOT put real passwords or secrets in this file!
# 
# 1. Copy this file and rename it to exactly: .env
# 2. Fill in the actual values in the new .env file
# 3. The real .env file is ignored by Git and will never be uploaded to GitHub
# ==============================================================================

# Database Connection (NeonDB PostgreSQL or Local MySQL/PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/your_database?sslmode=require
SPRING_DATASOURCE_USERNAME=your_database_user
SPRING_DATASOURCE_PASSWORD=your_database_password

# JWT Authentication
# Must be a secure, random hexadecimal string (at least 64 characters long)
# You can generate one online or use a password generator
JWT_SECRET=your_secure_64_character_hexadecimal_secret_key_goes_here_0123456789abcdef

# Docker Compose Database Initialisation (Optional - only used if starting DB via docker)
# If using a managed database like NeonDB, these are not required
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
